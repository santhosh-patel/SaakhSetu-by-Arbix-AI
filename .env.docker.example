# Copy to project root as .env for Docker Compose variable substitution:
#   cp .env.docker.example .env
#
# Also configure the backend (Groq advisor):
#   cp backend/.env.example backend/.env

# Groq API key (optional — advisor chat works offline without it)
GROQ_API_KEY=

# URL the browser uses to reach the API (host machine, not Docker service name)
VITE_API_URL=http://localhost:8000
