# SaakhSetu Backend Environment Variables Configuration

# Groq API Key for the SaakhSetu AI Credit Advisor Chatbot.
# Obtain a key from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Path to the SQLite database file used for persisting score records.
# Defaults to "saakhsetu.db" in the backend directory.
SAAKHSETU_DB_PATH=saakhsetu.db
